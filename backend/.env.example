# ═══════════════════════════════════════════════════════════════════════
# Billify CRM — Backend Environment Template
# Copy this file to .env and fill in your actual production values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════

# Application
NODE_ENV=production
PORT=5000
APP_NAME=Billify CRM
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Database - MySQL
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_strong_db_password
DB_DIALECT=mysql
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS — must match your production frontend domain exactly
CORS_ORIGIN=https://yourdomain.com

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# Logging (use 'warn' or 'error' in production)
LOG_LEVEL=warn
LOG_DIR=./logs

# Socket.IO
SOCKET_CORS_ORIGIN=https://yourdomain.com

# SMTP — use a real provider (SendGrid, Mailgun, SES, etc.) in production
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com


