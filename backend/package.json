{
  "name": "billify-crm-backend",
  "version": "1.0.0",
  "description": "Billify CRM Module - Backend API Server",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node seed-pipeline-stages.js && node src/server.js",
    "seed": "node src/seeders/initialSeed.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed": "npx sequelize-cli db:seed:all",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "billify",
    "crm",
    "pos"
  ],
  "author": "KLAYNZ",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@kenjiuno/msgreader": "^1.28.0",
    "bcryptjs": "2.4.3",
    "compression": "1.7.5",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "csv-parser": "^3.2.1",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-validator": "7.2.1",
    "handlebars": "^4.7.9",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "mailparser": "^3.9.10",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.12.0",
    "nodemailer": "^8.0.10",
    "puppeteer": "^25.1.0",
    "sequelize": "6.37.5",
    "socket.io": "4.8.1",
    "uuid": "11.0.5"
  },
  "devDependencies": {
    "nodemon": "3.1.9",
    "sequelize-cli": "6.6.2"
  }
}
